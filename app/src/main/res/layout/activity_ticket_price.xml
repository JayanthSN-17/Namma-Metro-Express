<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#001B6B">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ticket Price\nಟಿಕೆಟ್ ದರ"
            android:textColor="#FFFFFF"
            android:textSize="32sp"
            android:textStyle="bold"
            android:layout_gravity="center"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="From: Bengaluru\nಇಂದ: ಬೆಂಗಳೂರು"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:layout_marginTop="40dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="To: Mysuru\nಗೆ: ಮೈಸೂರು"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:layout_marginTop="20dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Class: Second Class\nದ್ವಿತೀಯ ವರ್ಗ"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:layout_marginTop="20dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Passengers: 1"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:layout_marginTop="20dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="₹145"
            android:textColor="#FFD600"
            android:textSize="60sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginTop="50dp"/>

        <Button
            android:id="@+id/confirmButton"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="CONFIRM / ದೃಢೀಕರಿಸಿ"
            android:textStyle="bold"
            android:textSize="22sp"
            android:textColor="#000000"
            android:backgroundTint="#FFD600"
            android:layout_marginTop="50dp"/>

    </LinearLayout>

</ScrollView>