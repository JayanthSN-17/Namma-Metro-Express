<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#001B6B">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2. Select Train &amp; Location\n ರೈಲು ಮತ್ತು ಸ್ಥಳ ಆಯ್ಕೆಮಾಡಿ"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="28sp"
            android:gravity="center"
            android:layout_gravity="center" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Train\nರೈಲು ಆಯ್ಕೆಮಾಡಿ"
            android:textColor="#FFD600"
            android:textStyle="bold"
            android:textSize="22sp"
            android:layout_marginTop="30dp" />

        <Spinner
            android:id="@+id/trainSpinner"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:background="#FFFFFF"
            android:layout_marginTop="10dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your Current Location\nನಿಮ್ಮ ಪ್ರಸ್ತುತ ಸ್ಥಳ"
            android:textColor="#FFD600"
            android:textStyle="bold"
            android:textSize="22sp"
            android:layout_marginTop="30dp" />

        <EditText
            android:id="@+id/locationInput"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:hint="Bengaluru"
            android:textSize="20sp"
            android:padding="15dp"
            android:background="#FFFFFF"
            android:layout_marginTop="10dp" />

        <Button
            android:id="@+id/nextButton"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:text="NEXT / ಮುಂದೆ"
            android:textStyle="bold"
            android:textSize="22sp"
            android:textColor="#000000"
            android:backgroundTint="#FFD600"
            android:layout_marginTop="40dp" />

    </LinearLayout>

</ScrollView>